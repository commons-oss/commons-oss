# Commons OSS — local dev environment.
# Copy to .env.local and adjust as needed. Never commit real secrets.

# ---- Database ----
# App role (RLS-enforced). Used by the running app at request time.
DATABASE_URL=postgres://commons_app:commons_app@localhost:5433/commons

# Admin role (BYPASSRLS). Used by migrations + seeds + tests that need to
# write across tenants. Compose seeds this role via docker/postgres-init/00-roles.sql.
DATABASE_URL_ADMIN=postgres://commons_admin:commons_admin@localhost:5433/commons

# ---- Auth ----
# Required. Signs the session JWT cookie. Must be ≥ 32 chars.
# Generate one with: openssl rand -base64 48
AUTH_SECRET=dev-only-secret-replace-me-with-32-bytes-or-more

# Public origin used to build absolute callback URLs.
AUTH_ORIGIN=http://localhost:3000

# ---- Logto (optional in Phase 1; stub provider runs when these are blank) ----
# Start Logto with: docker compose --profile logto up -d
LOGTO_ENDPOINT=http://localhost:3001
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_COOKIE_SECRET=replace-me-with-32-bytes-of-randomness

# ---- Public (browser-exposed) ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=de
