{
  "name": "commons-oss",
  "private": true,
  "version": "0.0.0",
  "description": "Open-source toolkit for Vereine, clubs, and associations.",
  "homepage": "https://github.com/commons-oss/commons-oss",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @commons-oss/db db:generate",
    "db:push": "pnpm --filter @commons-oss/db db:push",
    "db:migrate": "pnpm --filter @commons-oss/db db:migrate",
    "db:seed": "pnpm --filter @commons-oss/db db:seed:roles && pnpm --filter @commons-oss/db db:seed:dogfood",
    "db:reset": "pnpm --filter @commons-oss/db db:reset",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@commons-oss/config-eslint": "workspace:*",
    "@commons-oss/config-tsconfig": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
