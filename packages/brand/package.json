{
  "name": "@commons-oss/brand",
  "version": "2.0.0",
  "description": "Commons OSS brand assets: logo files, color tokens, typography references.",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/commons-oss/commons-oss.git",
    "directory": "packages/brand"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "logo",
    "fonts",
    "tokens.css",
    "fonts.css",
    "status.css",
    "tokens.js",
    "tokens.d.ts",
    "README.md"
  ],
  "main": "./tokens.js",
  "types": "./tokens.d.ts",
  "exports": {
    ".": {
      "types": "./tokens.d.ts",
      "default": "./tokens.js"
    },
    "./tokens.css": "./tokens.css",
    "./fonts.css": "./fonts.css",
    "./status.css": "./status.css",
    "./logo/*": "./logo/*",
    "./fonts/*": "./fonts/*"
  }
}
