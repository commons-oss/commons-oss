{
  "name": "@commons-oss/db",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./rls": "./src/rls.ts",
    "./internal": "./src/internal.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "dotenv -e ../../.env.local -- drizzle-kit generate",
    "db:push": "dotenv -e ../../.env.local -- drizzle-kit push",
    "db:migrate": "dotenv -e ../../.env.local -- tsx src/migrate.ts",
    "db:seed:roles": "dotenv -e ../../.env.local -- tsx src/seed/roles.ts",
    "db:seed:dogfood": "dotenv -e ../../.env.local -- tsx src/seed/dogfood.ts",
    "db:reset": "dotenv -e ../../.env.local -- tsx src/seed/reset.ts",
    "test": "dotenv -e ../../.env.local -- vitest run",
    "test:watch": "dotenv -e ../../.env.local -- vitest"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@commons-oss/config-eslint": "workspace:*",
    "@commons-oss/config-tsconfig": "workspace:*",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.18.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "dotenv-cli": "^11.0.0"
  }
}
